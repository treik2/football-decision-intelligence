# API Keys
ODDS_API_KEY=your_odds_api_key_here
OPENWEATHER_API_KEY=your_openweather_key_here
OPENAI_API_KEY=your_openai_key_here

# Database
POSTGRES_USER=fdi
POSTGRES_PASSWORD=fdi_secret
POSTGRES_DB=fdi
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://fdi:fdi_secret@postgres:5432/fdi

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# App
SECRET_KEY=change_me_in_production
DEBUG=true
LOG_LEVEL=INFO

# Monte Carlo
MC_SIMULATIONS=100000
MC_SEED=42

# Kelly
KELLY_FRACTION=0.25
MAX_STAKE_PCT=0.05
MIN_EV_THRESHOLD=0.01
MIN_CONFIDENCE=0.40
MAX_LEG_CORRELATION=0.60
